{
    "name": "etsy-seo-optimizer-backend",
    "version": "1.0.0",
    "description": "AI-powered Etsy listing optimization platform - Backend API",
    "main": "server.js",
    "scripts": {
        "start": "node src/server.js",
        "dev": "nodemon src/server.js",
        "seed": "node src/scripts/seed/seedSuperAdmin.js",
        "migrate": "node src/scripts/migration/migrateExistingCustomers.js",
        "migrate:database": "node src/scripts/migration/migrateSellersToCustomers.js",
        "test": "jest --config ../tests/backend/jest.config.js --forceExit --detectOpenHandles",
        "test:watch": "jest --config ../tests/backend/jest.config.js --watch --forceExit --detectOpenHandles",
        "test:verbose": "jest --config ../tests/backend/jest.config.js --verbose --forceExit --detectOpenHandles",
        "test:coverage": "jest --config ../tests/backend/jest.config.js --coverage --forceExit --detectOpenHandles"
    },
    "keywords": [
        "etsy",
        "ai",
        "optimization",
        "listing",
        "seo"
    ],
    "author": "Etsy SEO Optimizer",
    "license": "ISC",
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.6",
        "dotenv": "^16.6.1",
        "express": "^4.22.1",
        "express-validator": "^7.0.1",
        "google-auth-library": "^10.5.0",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^7.8.9",
        "multer": "^2.0.2",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.1",
        "pdfkit": "^0.17.2",
        "stripe": "^20.3.1"
    },
    "devDependencies": {
        "jest": "^29.7.0",
        "mongodb-memory-server": "^10.4.3",
        "nodemon": "^3.0.1",
        "supertest": "^7.2.2"
    }
}
